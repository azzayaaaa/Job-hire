generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  password         String?
  userType         String         @default("CANDIDATE") 
  credits          Int            @default(10)
  referralCode     String         @unique
  referredBy       Int?
  verificationCode String?        
  createdAt        DateTime       @default(now())
  
  fullName         String?
  image            String?
  phone            String?

  // Employer profile fields (used by employer dashboard)
  website          String?
  location         String?
  description      String?        @db.Text
  logo             String?        @db.LongText

  cvText           String?        @db.LongText
  cvFileName       String?
  skills           String?        @db.Text

  // Notification settings
  emailNotifications Boolean       @default(true)

  jobs             Job[]
  applications     JobApplication[]
  sentMessages     ChatMessage[]  @relation("SentMessages")
  receivedMessages ChatMessage[]  @relation("ReceivedMessages")
  studyPlans       StudyPlan[]
  sentNotifications Notification[] @relation("sender")
  receivedNotifications Notification[] @relation("receiver")
}

model Job {
  id          Int              @id @default(autoincrement())
  title       String
  description String           @db.Text
  requirements String          @db.Text
  location    String
  salary      String?
  category    String           @default("IT")
  jobType     String           @default("FULL_TIME")
  status      String           @default("ACTIVE")
  employerId  Int
  employer    User             @relation(fields: [employerId], references: [id])
  image       String?          @db.LongText
  applications JobApplication[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model JobApplication {
  id          Int      @id @default(autoincrement())
  jobId       Int
  candidateId Int
  status      String   @default("PENDING")
  matchScore  Int?     
  feedback    String?  @db.Text 
  job         Job      @relation(fields: [jobId], references: [id])
  candidate   User     @relation(fields: [candidateId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([jobId, candidateId])
}

model StudyPlan {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  content     String   @db.Text 
  status      String   @default("IN_PROGRESS")
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id          Int      @id @default(autoincrement())
  message     String   @db.Text
  senderId    Int
  receiverId  Int
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)
}

model Notification {
  id          Int      @id @default(autoincrement())
  senderId    Int
  receiverId  Int
  type        String   @default("JOB_OFFER")  // JOB_OFFER, JOB_SELECTED, JOB_REJECTED, MESSAGE
  title       String
  message     String   @db.Text
  link        String?
  isRead      Boolean  @default(false)
  sender      User     @relation("sender", fields: [senderId], references: [id])
  receiver    User     @relation("receiver", fields: [receiverId], references: [id])
  createdAt   DateTime @default(now())

  @@index([receiverId])
  @@index([senderId])
}
