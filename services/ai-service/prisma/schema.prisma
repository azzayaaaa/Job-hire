generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model aichat {
  id        String   @id
  title     String?
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([userId], map: "AIChat_userId_idx")
}

model aichatmessage {
  id        String   @id
  chatId    String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([chatId], map: "AIChatMessage_chatId_idx")
}

model chatmessage {
  id         Int      @id @default(autoincrement())
  message    String   @db.Text
  senderId   Int
  receiverId Int
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)
}

model job {
  id           Int      @id @default(autoincrement())
  title        String
  description  String   @db.Text
  requirements String   @db.Text
  location     String
  salary       String?
  category     String   @default("IT")
  jobType      String   @default("FULL_TIME")
  status       String   @default("ACTIVE")
  employerId   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model jobapplication {
  id          Int      @id @default(autoincrement())
  jobId       Int
  candidateId Int
  status      String   @default("PENDING")
  matchScore  Int?
  feedback    String?  @db.Text
  createdAt   DateTime @default(now())

  @@unique([jobId, candidateId], map: "JobApplication_jobId_candidateId_key")
}

model studyplan {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  content   String   @db.Text
  status    String   @default("IN_PROGRESS")
  createdAt DateTime @default(now())
}

model user {
  id               Int      @id @default(autoincrement())
  email            String   @unique(map: "User_email_key")
  password         String?
  userType         String   @default("CANDIDATE")
  credits          Int      @default(10)
  referralCode     String   @unique(map: "User_referralCode_key")
  referredBy       Int?
  verificationCode String?
  createdAt        DateTime @default(now())
  fullName         String?
  phone            String?
  cvText           String?  @db.Text
  skills           String?  @db.Text
}
